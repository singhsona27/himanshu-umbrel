COMPOSE_PROJECT_NAME=bsvsolo_perf
DEPLOY_ID=bsvsolo1

# Public ports. Change these when running multiple deployments on one server.
STRATUM_PORT=3336
DASHBOARD_PORT=8086
BSV_P2P_PORT=8334

# Official BSVN download page points Docker users to zquestz/bitcoin-sv.
# For production, pin a tested tag/digest after your first successful sync.
BSVN_IMAGE=zquestz/bitcoin-sv:latest
CKPOOL_IMAGE=ghcr.io/willitmod/wim-solo-ckpool:0.8.3-rc1-590fb2a

# Generated by scripts/init-env.sh or scripts/init-env.ps1.
RPC_USER=bsvrpc
RPC_PASSWORD=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE
BSV_MINING_ADDRESS=

# BSVN performance profile for a 4-core / 16GB server.
BSVN_DBCACHE_MB=6144
BSVN_PAR=3
BSVN_RPC_THREADS=8
BSVN_RPC_WORKQUEUE=128
BSVN_MAX_CONNECTIONS=96
BSVN_MAX_MEMPOOL_MB=1024

# Dashboard and coinbase signature text.
DASHBOARD_TITLE=BSV Solo Node
POOL_SIGNATURE=BSV Solo Q90 Nano
EXPECTED_HASHRATE_TH=97
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE
