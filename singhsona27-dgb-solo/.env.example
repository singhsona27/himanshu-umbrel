COMPOSE_PROJECT_NAME=dgbsha_solo
DEPLOY_ID=dgbsha1

# Change these if deploying beside other stacks on the same server.
STRATUM_PORT=3355
DASHBOARD_PORT=8095
DGB_P2P_PORT=12024

# Official DigiByte Core release version downloaded from DigiByte-Core/digibyte.
DIGIBYTE_VERSION=8.26.2

# Generated by scripts/init-env.sh or scripts/init-env.ps1.
RPC_USER=dgbrpc
RPC_PASSWORD=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE

# Required: set this to your DGB payout address before starting.
DGB_MINING_ADDRESS=CHANGE_ME_DGB_ADDRESS

# 4-core / 16GB server profile.
DGB_DBCACHE_MB=6144
DGB_PAR=3
DGB_RPC_THREADS=8
DGB_RPC_WORKQUEUE=128
DGB_MAX_CONNECTIONS=160
DGB_MAX_MEMPOOL_MB=768

# Avalon Q 90 TH/s + Avalon Nano 7 TH/s = about 97 TH/s.
EXPECTED_HASHRATE_TH=97
START_DIFF=10000
MIN_DIFF=1024
POOL_SIGNATURE=DGB SHA256 SOLO
DASHBOARD_TITLE=DGB SHA256 Solo Pool
