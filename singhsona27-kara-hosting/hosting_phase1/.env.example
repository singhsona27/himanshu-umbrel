# Karacraft Hosting V5 Cloudflare/Traefik domain settings
# Copy to .env before running install.sh if you want to change defaults.
BASE_DOMAIN=karacraft.ng
URL_SCHEME=https
PORTAL_DOMAIN=hosting.karacraft.ng
DB_DOMAIN=db.karacraft.ng
PLATFORM_ROOT=/home/umbrel/umbrel/home/Documents/hosting_phase1
APP_KEY=change-this-long-random-secret-before-production

# Optional SMTP password recovery.
# Recommended: create an app password or transactional SMTP credential.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=Karacraft Hosting

# Provider Cloudflare automation.
# Required for automatic custom-domain Tunnel onboarding.
# API token permissions: Account Cloudflare Tunnel Edit/Write.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_TUNNEL_SERVICE=http://umbrel.local:8088
