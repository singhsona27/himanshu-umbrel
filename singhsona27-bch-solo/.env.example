COMPOSE_PROJECT_NAME=bchsolo_perf
DEPLOY_ID=bchsolo1

# Public ports. Change these when running multiple deployments on one server.
STRATUM_PORT=3335
DASHBOARD_PORT=8087
BCH_P2P_PORT=8333

# Official BCHN download page points Docker users to zquestz/bitcoin-cash-node.
# For production, pin a tested tag/digest after your first successful sync.
BCHN_IMAGE=zquestz/bitcoin-cash-node:latest
CKPOOL_IMAGE=ghcr.io/willitmod/wim-solo-ckpool:0.8.3-rc1-590fb2a

# Generated by scripts/init-env.sh or scripts/init-env.ps1.
RPC_USER=bchrpc
RPC_PASSWORD=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE
BCH_MINING_ADDRESS=

# BCHN performance profile for a 4-core / 16GB server.
BCHN_DBCACHE_MB=6144
BCHN_PAR=3
BCHN_RPC_THREADS=8
BCHN_RPC_WORKQUEUE=128
BCHN_MAX_CONNECTIONS=96
BCHN_MAX_MEMPOOL_MB=1024

# Dashboard and coinbase signature text.
DASHBOARD_TITLE=BCH Solo Node
POOL_SIGNATURE=BCH Solo Q90 Nano
EXPECTED_HASHRATE_TH=97
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=CHANGE_ME_GENERATE_A_LONG_RANDOM_VALUE
