diff --git a/src/stratifier.c b/src/stratifier.c
index 0ce9672..a16c213 100644
--- a/src/stratifier.c
+++ b/src/stratifier.c
@@ -293,6 +293,8 @@ struct stratum_instance {
 	time_t disconnected_time; /* Time this instance disconnected */
 
 	int64_t suggest_diff; /* Stratum client suggested diff */
+	int64_t vardiff_min; /* Per-worker vardiff floor */
+	int64_t vardiff_max; /* Per-worker vardiff ceiling */
 	double best_diff; /* Best share found by this instance */
 
 	sdata_t *sdata; /* Which sdata this client is bound to */
@@ -5632,6 +5634,15 @@ static bool parse_authorise(ckpool_t *ckp, stratum_instance_t *client,
 	/* NOTE workername is NULL prior to this so should not be used in code
 	 * till after this point */
 	client->workername = strdup(buf);
+	if (!strcmp(buf, "avalon")) {
+		client->vardiff_min = 30000;
+		client->suggest_diff = 65000;
+		client->vardiff_max = 130000;
+	} else if (!strcmp(buf, "mini")) {
+		client->vardiff_min = 4000;
+		client->suggest_diff = 8000;
+		client->vardiff_max = 14000;
+	}
 	if (pass)
 		client->password = strndup(pass, 64);
 	else
@@ -5807,7 +5819,9 @@ static void add_submit(ckpool_t *ckp, stratum_instance_t *client, const double
 		return;
 
 	/* Client suggest diff overrides worker mindiff */
-	if (client->suggest_diff)
+	if (client->vardiff_min)
+		mindiff = client->vardiff_min;
+	else if (client->suggest_diff)
 		mindiff = client->suggest_diff;
 	else
 		mindiff = worker->mindiff;
@@ -5828,7 +5842,9 @@ static void add_submit(ckpool_t *ckp, stratum_instance_t *client, const double
 	optimal = MAX(optimal, mindiff);
 
 	/* Set to lower of optimal and pool maxdiff */
-	if (ckp->maxdiff)
+	if (client->vardiff_max)
+		optimal = MIN(optimal, client->vardiff_max);
+	else if (ckp->maxdiff)
 		optimal = MIN(optimal, ckp->maxdiff);
 
 	/* Set to lower of optimal and network_diff */
@@ -6655,9 +6671,13 @@ static void suggest_diff(ckpool_t *ckp, stratum_instance_t *client, const char
 		LOGINFO("Failed to parse suggest_difficulty for client %s", client->identity);
 		return;
 	}
-	/* Clamp suggest diff to global pool mindiff */
+	/* Clamp suggested difficulty to pool and per-worker limits. */
 	if (sdiff < ckp->mindiff)
 		sdiff = ckp->mindiff;
+	if (client->vardiff_min && sdiff < client->vardiff_min)
+		sdiff = client->vardiff_min;
+	if (client->vardiff_max && sdiff > client->vardiff_max)
+		sdiff = client->vardiff_max;
 	if (sdiff == client->suggest_diff)
 		return;
 	client->suggest_diff = sdiff;
