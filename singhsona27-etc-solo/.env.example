# Defaults are stored in config/app.env and can be edited from the dashboard.
ETC_COINBASE=

# Network ports exposed on your Umbrel LAN.
ETC_STRATUM_PORT=8018
ETC_HTTP_MINING_PORT=8898
ETC_P2P_PORT=30313

# CoreGeth tuning. Increase cache if your Umbrel has plenty of RAM.
GETH_CACHE_MB=4096
GETH_MAX_PEERS=100

# Two Jasminer X16-QE miners are roughly 3.3 GH/s total.
# This fixed diff targets about one accepted share every ~5 seconds per miner.
# Changing share difficulty affects stats/traffic, not the probability of finding a block.
ETC_SHARE_DIFFICULTY=8250000000
ETC_POOL_THREADS=4
ETC_BLOCK_REFRESH=120ms
ETC_STATE_REFRESH=2s
